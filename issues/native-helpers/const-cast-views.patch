From ffcd7420273e649a09304a77568e48b8b30ab8ea Mon Sep 17 00:00:00 2001
From: Neil Schemenauer <nas@arctrix.com>
Date: Wed, 20 May 2026 15:23:09 -0700
Subject: [PATCH] Drop const_cast in LinearLayout view bindings
X-Tier: 2
X-Severity: Significant
X-Issue-Id: FT031

get_shared_view / get_distributed_view used const_cast<LinearLayout &>
on a Python-shared layout to call getSharedLayoutStr /
getDistributedLayoutStr. Reading the implementations shows neither
helper actually mutates the layout; they only call const accessors
(apply, getInDimNames, getOutDimNames, getInDimSize, ...).

Change both helpers to take const LinearLayout & and drop the
const_cast at the binding sites. Two concurrent get_*_view calls on
the same Python LinearLayout now no longer write through aliased
mutable references.

Assisted-by: claude-opus-4.7
---
 include/triton/Dialect/TritonGPU/IR/Dialect.h | 5 +++--
 lib/Dialect/TritonGPU/IR/Dialect.cpp          | 7 ++++---
 python/src/linear_layout.cc                   | 6 +++---
 3 files changed, 10 insertions(+), 8 deletions(-)

diff --git a/include/triton/Dialect/TritonGPU/IR/Dialect.h b/include/triton/Dialect/TritonGPU/IR/Dialect.h
index 0a7866bf3..cf4ded733 100644
--- a/include/triton/Dialect/TritonGPU/IR/Dialect.h
+++ b/include/triton/Dialect/TritonGPU/IR/Dialect.h
@@ -283,10 +283,11 @@ void dumpHWLayout(RankedTensorType tensorType);
 std::string getLayoutStr(RankedTensorType tensorType, bool useHWPointOfView);
 
 // Return a string representation of the shared layout of the tensor.
-std::string getSharedLayoutStr(LinearLayout &ll, bool useHWPointOfView);
+std::string getSharedLayoutStr(const LinearLayout &ll, bool useHWPointOfView);
 
 // Return a string representation of the distributed layout of the tensor.
-std::string getDistributedLayoutStr(LinearLayout &ll, bool useHWPointOfView);
+std::string getDistributedLayoutStr(const LinearLayout &ll,
+                                    bool useHWPointOfView);
 
 template <typename T>
 llvm::SmallVector<T> expandMatrixShapeWithBatch(llvm::ArrayRef<T> s);
diff --git a/lib/Dialect/TritonGPU/IR/Dialect.cpp b/lib/Dialect/TritonGPU/IR/Dialect.cpp
index 102eaa396..9fb95875b 100644
--- a/lib/Dialect/TritonGPU/IR/Dialect.cpp
+++ b/lib/Dialect/TritonGPU/IR/Dialect.cpp
@@ -3652,7 +3652,7 @@ static std::string paddedString(int value, int max) {
   return str;
 }
 
-std::string mlir::triton::gpu::getSharedLayoutStr(LinearLayout &ll,
+std::string mlir::triton::gpu::getSharedLayoutStr(const LinearLayout &ll,
                                                   bool useHWPointOfView) {
   // This RankedTensorType is a MemDescType (?!)
   auto outDimNames = llvm::to_vector(ll.getOutDimNames());
@@ -3764,8 +3764,9 @@ std::string mlir::triton::gpu::getSharedLayoutStr(LinearLayout &ll,
   return layoutStr;
 }
 
-std::string mlir::triton::gpu::getDistributedLayoutStr(LinearLayout &ll,
-                                                       bool useHWPointOfView) {
+std::string
+mlir::triton::gpu::getDistributedLayoutStr(const LinearLayout &ll,
+                                           bool useHWPointOfView) {
   auto inDimNames = llvm::to_vector(ll.getInDimNames());
   auto *ctx = inDimNames[0].getContext();
   StringAttr kRegister = StringAttr::get(ctx, "register");
diff --git a/python/src/linear_layout.cc b/python/src/linear_layout.cc
index 21ad10125..4d0865593 100644
--- a/python/src/linear_layout.cc
+++ b/python/src/linear_layout.cc
@@ -176,13 +176,13 @@ void init_linear_layout(py::module &&m) {
       .def("__str__", [](const LinearLayout &self) { return self.toString(); })
       .def("get_shared_view",
            [](const LinearLayout &self, bool useHWPointOfView) {
-             return mlir::triton::gpu::getSharedLayoutStr(
-                 const_cast<LinearLayout &>(self), useHWPointOfView);
+             return mlir::triton::gpu::getSharedLayoutStr(self,
+                                                          useHWPointOfView);
            })
       .def("get_distributed_view",
            [](const LinearLayout &self, bool useHWPointOfView) {
              return mlir::triton::gpu::getDistributedLayoutStr(
-                 const_cast<LinearLayout &>(self), useHWPointOfView);
+                 self, useHWPointOfView);
            })
       .def(
           "apply",
