From 013ab78232c3fc5fd8ca9d7f6c2ae2907f575f79 Mon Sep 17 00:00:00 2001
From: Neil Schemenauer <nas@arctrix.com>
Date: Tue, 14 Apr 2026 10:38:08 -0700
Subject: [PATCH] Snapshot fn.__globals__ in get_capture_scope
X-Tier: 1
X-Severity: MED
X-Issue-Id: FT009
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

CodeGenerator iterates over __globals__ in a thread-unsafe way, since the dict
could be mutated while iterating.  Change get_capture_scope() to return
a copy of the dict.

Assisted-by: claude-opus-4.6

---
 python/triton/runtime/jit.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/python/triton/runtime/jit.py b/python/triton/runtime/jit.py
index ba21a58e1..74060c8fb 100644
--- a/python/triton/runtime/jit.py
+++ b/python/triton/runtime/jit.py
@@ -492,7 +492,7 @@ class JITCallable:
     def get_capture_scope(self):
         fn = self.fn
         if fn.__closure__ is None:
-            return self.__globals__
+            return dict(self.__globals__)
         nonlocals = {name: cell.cell_contents for name, cell in zip(fn.__code__.co_freevars, fn.__closure__)}
         return self.__globals__ | nonlocals
 
-- 
2.47.3

