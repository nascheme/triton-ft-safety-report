From 261785cc4f26cc38e6700e71aa4815782220998d Mon Sep 17 00:00:00 2001
From: Neil Schemenauer <nas@arctrix.com>
Date: Tue, 14 Apr 2026 10:42:53 -0700
Subject: [PATCH] Serialize DriverConfig lazy init and set_active/reset_active
X-Rank: Blocker
X-Issue-Id: FT040

Serialize the lazy init of DriverConfig._default and _active.  This
avoids data races when multiple threads are used.

Assisted-by: claude-opus-4.6

---
 python/triton/runtime/driver.py | 39 ++++++++++++++++++++++++++-------
 1 file changed, 31 insertions(+), 8 deletions(-)

diff --git a/python/triton/runtime/driver.py b/python/triton/runtime/driver.py
index 5801b42fd..d13146633 100644
--- a/python/triton/runtime/driver.py
+++ b/python/triton/runtime/driver.py
@@ -1,6 +1,7 @@
 from __future__ import annotations
 
 import os
+import threading
 
 from ..backends import backends, DriverBase
 
@@ -26,24 +27,46 @@ class DriverConfig:
     def __init__(self) -> None:
         self._default: DriverBase | None = None
         self._active: DriverBase | None = None
+        # Serializes lazy init of _default / _active and any explicit
+        # set_active / reset_active calls so that under free-threaded
+        # CPython two threads cannot concurrently construct duplicate
+        # backend drivers or race a lazy init against an explicit override.
+        self._lock = threading.Lock()
 
     @property
     def default(self) -> DriverBase:
-        if self._default is None:
-            self._default = _create_driver()
-        return self._default
+        default = self._default
+        if default is not None:
+            return default
+        with self._lock:
+            if self._default is None:
+                self._default = _create_driver()
+            return self._default
 
     @property
     def active(self) -> DriverBase:
-        if self._active is None:
-            self._active = self.default
-        return self._active
+        active = self._active
+        if active is not None:
+            return active
+        with self._lock:
+            if self._active is None:
+                # self.default takes the same lock recursively-safe path
+                # via its own fast check; call _default directly to avoid
+                # re-entering the lock.
+                if self._default is None:
+                    self._default = _create_driver()
+                self._active = self._default
+            return self._active
 
     def set_active(self, driver: DriverBase) -> None:
-        self._active = driver
+        with self._lock:
+            self._active = driver
 
     def reset_active(self) -> None:
-        self._active = self.default
+        with self._lock:
+            if self._default is None:
+                self._default = _create_driver()
+            self._active = self._default
 
 
 driver = DriverConfig()
-- 
